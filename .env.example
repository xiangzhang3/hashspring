# HashSpring Environment Variables
# Copy this to .env.local and fill in the values

# Anthropic API Key (for AI translation pipeline)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# CoinGecko API Key (optional, free tier works without key)
# COINGECKO_API_KEY=

# Site URL (used for SEO, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://hashspring.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
